<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="robots" content="index,follow">
<meta name="description" content="Compliance dashboard for 273 Ventures open-source KAOS packages. Build, security, license, and governance evidence regenerated daily.">
<base href="{{ base_href | default('/kaos-compliance/') }}">
<title>KAOS Compliance Dashboard — 273 Ventures</title>
{#
  Expected data shape (snapshot.json) — keep in sync with collector.
  {
    "generated_at": "2026-05-11T14:02:00Z",
    "org": {
      "composite_green": 14, "composite_total": 16,
      "build_pass": 15, "tests_pass": 14,
      "advisories": {"critical": 0, "high": 2, "moderate": 5, "low": 1},
      "signed_releases": 11, "license_clean": 16,
      "commits_90d": 2341, "maintainers": 8
    },
    "packages": [
      {"name":"kaos-core","version":"1.4.2","build":"green","tests":"green",
       "security":"green","signing":"green","license":"green","deps":"yellow",
       "last_release":"2026-05-08","release_age_days":3}
    ]
  }
#}
<style>
:root{
 --s-1:4px;--s-2:8px;--s-3:12px;--s-4:16px;--s-5:24px;--s-6:32px;--s-7:48px;
 --page-bg:#fff;--card-bg:#fafbfc;--border:#e5e7eb;--text:#111827;--muted:#6b7280;
 --g-bg:#e6f4ea;--g-fg:#1e7e34;--y-bg:#fff8e1;--y-fg:#8a6d00;
 --r-bg:#fdecea;--r-fg:#b42318;--n-bg:#f3f4f6;--n-fg:#4b5563;
 --focus:#2563eb;
 --mono:ui-monospace,"SF Mono",Menlo,Consolas,"Liberation Mono",monospace;
 --sans:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;
}
@media (prefers-color-scheme: dark){
 :root{--page-bg:#0b0f14;--card-bg:#11161d;--border:#1f2937;--text:#e5e7eb;--muted:#9ca3af;
  --g-bg:#14271b;--g-fg:#4ade80;--y-bg:#2a2410;--y-fg:#facc15;
  --r-bg:#2a1414;--r-fg:#f87171;--n-bg:#1f2937;--n-fg:#9ca3af;--focus:#60a5fa;}
}
*{box-sizing:border-box}
html,body{margin:0;padding:0;background:var(--page-bg);color:var(--text);font-family:var(--sans);font-size:16px;line-height:1.5}
a{color:var(--focus);text-decoration:underline;text-underline-offset:2px}
a:focus-visible,button:focus-visible{outline:2px solid var(--focus);outline-offset:2px;border-radius:2px}
.wrap{max-width:1200px;margin:0 auto;padding:var(--s-7) var(--s-5)}
.page-head{display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:var(--s-3);border-bottom:1px solid var(--border);padding-bottom:var(--s-4);margin-bottom:var(--s-6)}
.page-head h1{margin:0;font-size:2rem;line-height:1.1}
.page-head p{margin:var(--s-1) 0 0;color:var(--muted);font-size:0.875rem}
.page-head .meta{font-family:var(--mono);font-size:0.75rem;color:var(--muted)}
h2{font-size:1.5rem;line-height:1.25;margin:var(--s-6) 0 var(--s-3);font-weight:600}
.card{background:var(--card-bg);border:1px solid var(--border);border-radius:6px;padding:var(--s-4)}
.rollup{padding:var(--s-5)}
.rollup-head{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:var(--s-3);margin-bottom:var(--s-3)}
.rollup-head .label{font-weight:600;font-size:1.125rem}
.rollup-head .score{font-family:var(--mono);font-weight:700;font-size:1.25rem}
.bar{height:10px;background:var(--n-bg);border-radius:2px;overflow:hidden;border:1px solid var(--border)}
.bar>span{display:block;height:100%;background:var(--g-fg)}
.rollup-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--s-4);margin-top:var(--s-4)}
.rollup-grid .cell{font-size:0.875rem}
.rollup-grid .cell .n{display:block;font-family:var(--mono);font-size:1.5rem;font-weight:700;line-height:1.1}
.rollup-grid .cell .lab{color:var(--muted);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.04em}
.strip{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--s-4);margin-top:var(--s-5)}
.strip .stat{background:var(--card-bg);border:1px solid var(--border);border-radius:6px;padding:var(--s-3) var(--s-4)}
.strip .stat .n{font-family:var(--mono);font-size:1.75rem;font-weight:700;line-height:1.1;display:block}
.strip .stat .lab{color:var(--muted);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.04em}
table.grid{width:100%;border-collapse:collapse;font-size:0.875rem}
table.grid th,table.grid td{padding:var(--s-3) var(--s-2);text-align:left;border-bottom:1px solid var(--border);vertical-align:middle}
table.grid th{font-weight:600;color:var(--muted);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.04em;background:transparent}
table.grid tbody tr:nth-child(even){background:rgba(0,0,0,0.02)}
@media (prefers-color-scheme: dark){table.grid tbody tr:nth-child(even){background:rgba(255,255,255,0.04)}}
table.grid td.pkg{font-weight:600}
table.grid td.ver{font-family:var(--mono);color:var(--muted)}
table.grid td.age{color:var(--muted);font-size:0.8125rem}
.pill{display:inline-flex;align-items:center;gap:var(--s-2);padding:2px 8px;border-radius:3px;font-size:0.75rem;font-weight:600;line-height:1.4;border:1px solid transparent;text-decoration:none}
a.pill:hover{filter:brightness(0.95);text-decoration:underline}
a.pill:focus-visible{outline:2px solid var(--focus);outline-offset:2px}
.pill .gly{font-family:var(--mono);font-weight:700}
.pill .wd{font-size:0.6875rem;text-transform:uppercase;letter-spacing:0.04em}
.pill.g{background:var(--g-bg);color:var(--g-fg);border-color:var(--g-fg)}
.pill.y{background:var(--y-bg);color:var(--y-fg);border-color:var(--y-fg)}
.pill.r{background:var(--r-bg);color:var(--r-fg);border-color:var(--r-fg)}
.pill.n{background:var(--n-bg);color:var(--n-fg);border-color:var(--n-fg)}
footer{margin-top:var(--s-7);padding-top:var(--s-4);border-top:1px solid var(--border);color:var(--muted);font-size:0.75rem;font-family:var(--mono)}
footer a{color:var(--muted)}
nav.subnav{margin-top:var(--s-3);display:flex;gap:var(--s-4);flex-wrap:wrap;font-size:0.875rem}
nav.subnav a{color:var(--muted)}
.skip{position:absolute;left:-9999px}
.skip:focus{position:static;display:inline-block;padding:var(--s-2);background:var(--y-bg);color:var(--y-fg)}
@media (max-width:720px){
 .wrap{padding:var(--s-5) var(--s-4)}
 .page-head h1{font-size:1.5rem}
 .rollup-grid,.strip{grid-template-columns:1fr 1fr}
 table.grid thead{display:none}
 table.grid,table.grid tbody,table.grid tr,table.grid td{display:block;width:100%}
 table.grid tr{border:1px solid var(--border);border-radius:6px;margin-bottom:var(--s-3);padding:var(--s-3)}
 table.grid td{border:0;padding:var(--s-1) 0;display:flex;justify-content:space-between;gap:var(--s-3)}
 table.grid td::before{content:attr(data-h);color:var(--muted);font-size:0.6875rem;text-transform:uppercase;letter-spacing:0.04em}
}
@media print{
 :root{--page-bg:#fff;--card-bg:#fff;--text:#000;--muted:#444;--border:#999}
 a{color:#000;text-decoration:none}
 .wrap{padding:0;max-width:none}
 .card,.strip .stat{box-shadow:none}
 .pill{background:#fff!important;color:#000!important;border:1px solid #000}
 nav.subnav,.skip{display:none}
}
</style>
</head>
<body>
<a class="skip" href="#main">Skip to content</a>
<div class="wrap">
<header class="page-head">
 <div>
  <h1>KAOS Compliance Dashboard</h1>
  <p>273 Ventures open-source packages — auditor view</p>
  <nav class="subnav" aria-label="Sections">
   <a href="security.html">Security</a>
   <a href="supply-chain.html">Supply chain</a>
   <a href="governance.html">Governance</a>
   <a href="diary.html">Diary</a>
   <a href="methodology.html">Methodology</a>
  </nav>
  {# Integrity claim (R4): tie each render to a sigstore signature on
     api/v1/snapshot.json. Pill renders green only when the workflow
     attached a cosign bundle; local renders show gray with the same
     verify-recipe link so curious readers can still see how it would
     be checked. The link goes to docs/EVIDENCE.md on the canonical
     repo (the deployed site doesn't carry docs/, so we link upstream). #}
  {% if integrity is defined %}
   {% set _state = integrity.signature_state | default('gray') %}
   {% set _cls = {'green': 'g', 'yellow': 'y', 'red': 'r', 'gray': 'n'}[_state] %}
   {% set _label = 'snapshot signed' if integrity.signature_present else 'snapshot unsigned (local render)' %}
   <p class="integrity-claim" style="margin-top:var(--s-3);font-size:0.8125rem">
    <span class="pill {{ _cls }}" aria-label="Snapshot signature status">
     <span class="gly" aria-hidden="true">{% if integrity.signature_present %}✓{% else %}—{% endif %}</span>
     <span class="wd">{{ _label }}</span>
    </span>
    {% if integrity.signature_present and integrity.signature_url %}
     &middot; <a href="{{ integrity.signature_url }}">snapshot.sig</a>
    {% endif %}
    &middot; <a href="{{ integrity.verify_recipe_url }}">verify recipe</a>
    {% if integrity.schema_url %}
     &middot; <a href="{{ integrity.schema_url }}">JSON Schema</a>
    {% endif %}
   </p>
  {% endif %}
 </div>
 <div class="meta" aria-label="Last generated">
  Generated {{ generated_at_display | default('2026-05-11 14:02 UTC') }}
 </div>
</header>

<main id="main">
<section aria-labelledby="rollup-h">
 <h2 id="rollup-h">Org rollup</h2>
 <div class="card rollup">
  <div class="rollup-head">
   <div class="label">Composite trust</div>
   <div class="score" aria-label="Composite score">
    {{ org.composite_green | default(14) }} / {{ org.composite_total | default(16) }} packages green
   </div>
  </div>
  {% set pct = ((org.composite_green | default(14)) * 100 // (org.composite_total | default(16))) %}
  <div class="bar" role="img" aria-label="{{ pct }} percent of packages meeting bar">
   <span style="width:{{ pct }}%"></span>
  </div>
  <div class="rollup-grid">
   <div class="cell"><span class="n">{{ org.build_pass | default(15) }}/{{ org.composite_total | default(16) }}</span><span class="lab">Build passing</span></div>
   <div class="cell"><span class="n">{{ org.tests_pass | default(14) }}/{{ org.composite_total | default(16) }}</span><span class="lab">Tests passing</span></div>
   <div class="cell"><span class="n">{{ org.signed_releases | default(11) }}/{{ org.composite_total | default(16) }}</span><span class="lab">Signed releases</span></div>
   <div class="cell"><span class="n">{{ org.license_clean | default(16) }}/{{ org.composite_total | default(16) }}</span><span class="lab">License clean</span></div>
  </div>
 </div>
</section>

<section aria-labelledby="strip-h">
 <h2 id="strip-h" class="sr-only" style="position:absolute;left:-9999px">Headline metrics</h2>
 <div class="strip">
  <div class="stat"><span class="n">{{ org.repos_total | default(16) }}</span><span class="lab">Repositories</span></div>
  <div class="stat"><span class="n">{{ org.commits_total | default('—') }}</span><span class="lab">Commits</span></div>
  <div class="stat"><span class="n">{{ org.tests_total | default('—') }}</span><span class="lab">Tests</span></div>
  <div class="stat"><span class="n">{{ org.platforms_total | default('—') }}</span><span class="lab">Supported platforms</span></div>
 </div>
</section>

<section aria-labelledby="code-strip-h">
 <h2 id="code-strip-h" class="sr-only" style="position:absolute;left:-9999px">Code surface area</h2>
 <div class="strip" style="margin-top:var(--s-3)">
  <div class="stat">
   <span class="n">{% if org.loc_total is number %}{{ '{:,}'.format(org.loc_total) }}{% else %}{{ org.loc_total | default('—') }}{% endif %}</span>
   <span class="lab">Lines of code (hand-written)</span>
  </div>
  <div class="stat">
   <span class="n">{% if org.files_total is number %}{{ '{:,}'.format(org.files_total) }}{% else %}{{ org.files_total | default('—') }}{% endif %}</span>
   <span class="lab">Source + test files</span>
  </div>
  <div class="stat">
   <span class="n">{% if org.py_src_loc is number %}{{ '{:,}'.format(org.py_src_loc) }}{% else %}—{% endif %}</span>
   <span class="lab">Python src LoC</span>
  </div>
  <div class="stat">
   <span class="n">{% if org.rs_src_loc is number %}{{ '{:,}'.format(org.rs_src_loc) }}{% else %}—{% endif %}</span>
   <span class="lab">Rust src LoC</span>
  </div>
 </div>
</section>

<section aria-labelledby="grid-h">
 <h2 id="grid-h">Packages</h2>
 <table class="grid" aria-describedby="grid-h">
  <thead>
   <tr>
    <th scope="col">Package</th>
    <th scope="col">Version</th>
    <th scope="col">Build</th>
    <th scope="col">Tests</th>
    <th scope="col">Security</th>
    <th scope="col">Signing</th>
    <th scope="col">License</th>
    <th scope="col">Deps</th>
    <th scope="col">Last release</th>
   </tr>
  </thead>
  <tbody>
   {% for p in packages | default([
     {"name":"kaos-core","version":"1.4.2","build":"green","tests":"green","security":"green","signing":"green","license":"green","deps":"yellow","last_release_display":"3 days ago"},
     {"name":"kaos-cli","version":"0.9.1","build":"green","tests":"green","security":"green","signing":"red","license":"green","deps":"green","last_release_display":"11 days ago"},
     {"name":"kaos-eval","version":"0.3.0","build":"green","tests":"yellow","security":"green","signing":"gray","license":"green","deps":"green","last_release_display":"46 days ago"}
   ]) %}
   {% set states = {"green":["g","✓","Pass"],"yellow":["y","⚠","Warn"],"red":["r","✗","Fail"],"gray":["n","—","No signal"]} %}
   <tr>
    <td class="pkg" data-h="Package"><a href="package/{{ p.name }}.html">{{ p.name }}</a></td>
    <td class="ver" data-h="Version">{{ p.version }}</td>
    {% for col in ["build","tests","security","signing","license","deps"] %}
     {% set st = states[p[col]] %}
     {% set link = (p.pill_links or {})[col] %}
     <td data-h="{{ col | capitalize }}">
      {% if link %}
       <a class="pill {{ st[0] }}" href="{{ link }}" target="_blank" rel="noopener" aria-label="{{ col | capitalize }}: {{ st[2] }} — open evidence">
        <span class="gly" aria-hidden="true">{{ st[1] }}</span><span class="wd">{{ st[2] }}</span>
       </a>
      {% else %}
       <span class="pill {{ st[0] }}" aria-label="{{ col | capitalize }}: {{ st[2] }}">
        <span class="gly" aria-hidden="true">{{ st[1] }}</span><span class="wd">{{ st[2] }}</span>
       </span>
      {% endif %}
     </td>
    {% endfor %}
    <td class="age" data-h="Last release">{{ p.last_release_display }}</td>
   </tr>
   {% endfor %}
  </tbody>
 </table>
</section>
</main>

<footer>
 Generated {{ generated_at_display | default('2026-05-11 14:02 UTC') }}
 | Source: <a href="https://github.com/273v/kaos-compliance">github.com/273v/kaos-compliance</a>
 | Methodology: <a href="methodology.html">methodology.html</a>
 | Data: <a href="api/v1/snapshot.json">snapshot.json</a>
 {% if integrity is defined and integrity.schema_url %}
  | Schema: <a href="{{ integrity.schema_url }}">snapshot.schema.json</a>
 {% endif %}
 {% if integrity is defined and integrity.signature_present and integrity.signature_url %}
  | Signature: <a href="{{ integrity.signature_url }}">snapshot.sig</a>
  (<a href="{{ integrity.verify_recipe_url }}">verify recipe</a>)
 {% else %}
  | <a href="{{ integrity.verify_recipe_url if integrity is defined else 'https://github.com/273v/kaos-compliance/blob/main/docs/EVIDENCE.md' }}">how to verify</a>
 {% endif %}
</footer>
</div>
</body>
</html>
