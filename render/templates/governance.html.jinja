<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="robots" content="index,follow">
<meta name="description" content="Org-wide governance + velocity rollup for the 273 Ventures KAOS open-source ecosystem.">
<base href="{{ base_href | default('/kaos-compliance/') }}">
<title>Governance — KAOS Compliance</title>
{# Expected: governance_summary {org_dco_rate, org_cc_rate, commits_90d, releases_90d,
   branch_protection_count, branch_protection_total, codeowners_count, codeowners_total,
   security_md_count, security_md_total, notice_count, notice_total,
   time_to_pypi_median_seconds, packages: [{name, dco_rate, cc_rate, verified_rate,
   commits_90d, releases_90d, branch_protection, codeowners, security_md, notice,
   median_pr_age_days, time_to_pypi_seconds_median}]}.
   Anti-patterns honored: no composite governance score; no maintainer identity;
   no GitHub stars / fork counts; no binary "signed commits" pill — verified_rate
   is always paired with branch_protection state. #}
<style>
:root{
 --s-1:4px;--s-2:8px;--s-3:12px;--s-4:16px;--s-5:24px;--s-6:32px;--s-7:48px;
 --page-bg:#fff;--card-bg:#fafbfc;--border:#e5e7eb;--text:#111827;--muted:#6b7280;
 --g-bg:#e6f4ea;--g-fg:#1e7e34;--y-bg:#fff8e1;--y-fg:#8a6d00;
 --r-bg:#fdecea;--r-fg:#b42318;--n-bg:#f3f4f6;--n-fg:#4b5563;--focus:#2563eb;
 --mono:ui-monospace,"SF Mono",Menlo,Consolas,"Liberation Mono",monospace;
 --sans:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;
}
@media (prefers-color-scheme: dark){:root{--page-bg:#0b0f14;--card-bg:#11161d;--border:#1f2937;--text:#e5e7eb;--muted:#9ca3af;--g-bg:#14271b;--g-fg:#4ade80;--y-bg:#2a2410;--y-fg:#facc15;--r-bg:#2a1414;--r-fg:#f87171;--n-bg:#1f2937;--n-fg:#9ca3af;--focus:#60a5fa;}}
*{box-sizing:border-box}
html,body{margin:0;padding:0;background:var(--page-bg);color:var(--text);font-family:var(--sans);line-height:1.5;font-size:16px}
body{padding:var(--s-5);max-width:1240px;margin:0 auto}
a{color:var(--focus)}
header{padding-bottom:var(--s-5);border-bottom:1px solid var(--border);margin-bottom:var(--s-5)}
header h1{font-size:1.5rem;margin:0 0 var(--s-2)}
header .meta{color:var(--muted);font-size:0.875rem;font-family:var(--mono)}
nav.subnav{margin-top:var(--s-3);display:flex;gap:var(--s-4);flex-wrap:wrap;font-size:0.875rem}
nav.subnav a{color:var(--muted)}
nav.subnav a[aria-current=page]{color:var(--text);font-weight:600}
nav.subnav a.methodology{font-weight:600;color:var(--text);border-bottom:1px dotted var(--text)}
.skip{position:absolute;left:-9999px}
.skip:focus{position:static;display:inline-block;padding:var(--s-2);background:var(--y-bg);color:var(--y-fg)}
h2{font-size:1.125rem;margin:var(--s-6) 0 var(--s-3)}
.card{background:var(--card-bg);border:1px solid var(--border);border-radius:6px;padding:var(--s-5);margin-bottom:var(--s-4)}
.strip{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--s-3)}
.stat{background:var(--card-bg);border:1px solid var(--border);border-radius:6px;padding:var(--s-4)}
.stat .n{display:block;font-size:1.5rem;font-weight:700;font-family:var(--mono)}
.stat .lab{display:block;color:var(--muted);font-size:0.8125rem;text-transform:uppercase;letter-spacing:0.04em;margin-top:var(--s-1)}
.pill{display:inline-flex;align-items:center;gap:var(--s-2);padding:2px 8px;border-radius:3px;font-size:0.75rem;font-weight:600;line-height:1.4;border:1px solid transparent}
.pill .gly{font-family:var(--mono);font-weight:700}
.pill .wd{font-size:0.6875rem;text-transform:uppercase;letter-spacing:0.04em}
.pill.g{background:var(--g-bg);color:var(--g-fg);border-color:var(--g-fg)}
.pill.y{background:var(--y-bg);color:var(--y-fg);border-color:var(--y-fg)}
.pill.r{background:var(--r-bg);color:var(--r-fg);border-color:var(--r-fg)}
.pill.n{background:var(--n-bg);color:var(--n-fg);border-color:var(--n-fg)}
table{width:100%;border-collapse:collapse;font-size:0.875rem}
th,td{padding:var(--s-2) var(--s-3);text-align:left;border-bottom:1px solid var(--border)}
th{font-weight:600;color:var(--muted);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.04em}
td.num{font-family:var(--mono);text-align:right}
footer{margin-top:var(--s-7);padding-top:var(--s-4);border-top:1px solid var(--border);color:var(--muted);font-size:0.75rem;font-family:var(--mono)}
footer a{color:var(--muted)}
@media (max-width:720px){body{padding:var(--s-4)} .strip{grid-template-columns:repeat(2,1fr)} table{display:block;overflow-x:auto}}
@media print{body{padding:0;color:#000;background:#fff;max-width:none} a{color:#000;text-decoration:underline} .pill{background:#fff!important;color:#000!important;border:1px solid #000}}
</style>
</head>
<body>
<a class="skip" href="#main">Skip to content</a>
<header>
 <h1>Governance &amp; velocity</h1>
 <nav class="subnav">
  <a href="index.html">Org rollup</a>
  <a href="methodology.html" class="methodology">Methodology</a>
  <a href="security.html">Security</a>
  <a href="supply-chain.html">Supply chain</a>
  <a href="governance.html" aria-current="page">Governance</a>
  <a href="diary.html">Diary</a>
 </nav>
 <div class="meta">Generated {{ generated_at_display | default('—') }} · No composite score. Surface signals; never invent them.</div>
</header>

<main id="main">

<section>
 <div class="strip">
  <div class="stat"><span class="n">{% if governance_summary.org_dco_rate is not none %}{{ '%.0f' | format(governance_summary.org_dco_rate * 100) }}%{% else %}—{% endif %}</span><span class="lab">Org DCO sign-off (90d avg)</span></div>
  <div class="stat"><span class="n">{% if governance_summary.org_cc_rate is not none %}{{ '%.0f' | format(governance_summary.org_cc_rate * 100) }}%{% else %}—{% endif %}</span><span class="lab">Conventional commits (90d avg)</span></div>
  <div class="stat"><span class="n">{{ governance_summary.commits_90d | default('—') }}</span><span class="lab">Commits last 90d</span></div>
  <div class="stat"><span class="n">{{ governance_summary.releases_90d | default('—') }}</span><span class="lab">Releases last 90d</span></div>
 </div>
</section>

<section>
 <h2>Repo hygiene</h2>
 <div class="card">
  <table>
   <thead><tr><th>Signal</th><th>Coverage</th><th>Notes</th></tr></thead>
   <tbody>
    <tr><td>Branch protection on <code>main</code></td><td class="num">{{ governance_summary.branch_protection_count | default(0) }} / {{ governance_summary.branch_protection_total | default(0) }}</td><td>Required reviews + status checks. False on a private alpha is acceptable; it should flip before GA.</td></tr>
    <tr><td><code>CODEOWNERS</code> present</td><td class="num">{{ governance_summary.codeowners_count | default(0) }} / {{ governance_summary.codeowners_total | default(0) }}</td><td>Path-scoped reviewer routing; pairs with branch protection's required-reviewers rule.</td></tr>
    <tr><td><code>SECURITY.md</code> present</td><td class="num">{{ governance_summary.security_md_count | default(0) }} / {{ governance_summary.security_md_total | default(0) }}</td><td>NIST SSDF RV.1.3 + CRA Annex I Part II §5.</td></tr>
    <tr><td><code>NOTICE</code> shipped</td><td class="num">{{ governance_summary.notice_count | default(0) }} / {{ governance_summary.notice_total | default(0) }}</td><td>Apache-2.0 §4 attribution.</td></tr>
    <tr><td>Median time tag → PyPI publish</td><td class="num">{% if governance_summary.time_to_pypi_median_seconds %}{{ governance_summary.time_to_pypi_median_seconds }} s{% else %}—{% endif %}</td><td>Provenance latency. Tight numbers (&lt;60s) suggest direct CI-driven publish via Trusted Publisher.</td></tr>
   </tbody>
  </table>
 </div>
</section>

<section>
 <h2>Per-package signals</h2>
 <div class="card">
  <table>
   <thead><tr><th>Package</th><th>DCO 90d</th><th>CC 90d</th><th>Verified 90d</th><th>Commits</th><th>Releases</th><th>Branch prot.</th><th>Time→PyPI</th></tr></thead>
   <tbody>
    {% for row in governance_summary.packages | default([]) %}
    <tr>
     <td><a href="package/{{ row.name }}.html">{{ row.name }}</a></td>
     <td class="num">{% if row.dco_rate is not none %}{{ '%.0f' | format(row.dco_rate * 100) }}%{% else %}—{% endif %}</td>
     <td class="num">{% if row.cc_rate is not none %}{{ '%.0f' | format(row.cc_rate * 100) }}%{% else %}—{% endif %}</td>
     <td class="num">{% if row.verified_rate is not none %}{{ '%.0f' | format(row.verified_rate * 100) }}%{% else %}—{% endif %}</td>
     <td class="num">{{ row.commits_90d | default('—') }}</td>
     <td class="num">{{ row.releases_90d | default('—') }}</td>
     <td>{% if row.branch_protection is none %}<span class="pill n" aria-label="Branch protection: No signal"><span class="gly" aria-hidden="true">—</span><span class="wd" aria-hidden="true">No signal</span></span>{% elif row.branch_protection %}<span class="pill g" aria-label="Branch protection: On"><span class="gly" aria-hidden="true">✓</span><span class="wd" aria-hidden="true">On</span></span>{% else %}<span class="pill y" aria-label="Branch protection: Off"><span class="gly" aria-hidden="true">⚠</span><span class="wd" aria-hidden="true">Off</span></span>{% endif %}</td>
     <td class="num">{% if row.time_to_pypi_seconds_median %}{{ row.time_to_pypi_seconds_median }} s{% else %}—{% endif %}</td>
    </tr>
    {% endfor %}
   </tbody>
  </table>
 </div>
</section>

<section>
 <h2>What we deliberately do not show</h2>
 <div class="card" style="color:var(--muted);font-size:0.875rem">
  <ul>
   <li><strong>No composite governance score.</strong> Buyers see through scores; they incentivize gaming cheap signals. We surface every signal raw.</li>
   <li><strong>No maintainer identity</strong> (country, employer, real name). Encourages discrimination and false-positives on pseudonymous-but-trusted maintainers.</li>
   <li><strong>No GitHub stars / fork counts.</strong> <code>event-stream</code>, <code>colors.js</code>, and <code>ua-parser-js</code> were all high-star at the moment of compromise.</li>
   <li><strong>Verified commit ratio is never a binary green pill.</strong> Without branch-protection-required-signatures, a signed-commit ratio is decorative.</li>
  </ul>
 </div>
</section>

</main>
<footer>Generated {{ generated_at_display | default('—') }} · Source: <a href="https://github.com/273v/kaos-compliance">github.com/273v/kaos-compliance</a> · <a href="methodology.html">Methodology</a></footer>
</body>
</html>
